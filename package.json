{
  "name": "weixin-kimi-bot",
  "version": "0.3.9",
  "description": "通过微信消息远程操控 Kimi Code CLI —— 基于腾讯 iLink 协议的微信 AI Bot",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc",
    "start": "node --import tsx src/index.ts",
    "login": "node --import tsx src/login.ts",
    "config": "node --import tsx src/config.ts",
    "schedule": "node --import tsx src/scheduler-cli.ts",
    "notify": "node --import tsx src/notifications/cli.ts",
    "agent:list": "node --import tsx src/agent/cli.ts list",
    "agent:switch": "node --import tsx src/agent/cli.ts switch",
    "agent:config": "node --import tsx src/agent/cli.ts config",
    "agent:template": "node --import tsx src/agent/cli.ts template",
    "agent:memory": "node --import tsx src/agent/cli.ts memory",
    "agent:delete": "node --import tsx src/agent/cli.ts delete",
    "migrate": "node scripts/migrate-to-multi-agent.js",
    "version:patch": "node scripts/bump-version.js patch",
    "version:minor": "node scripts/bump-version.js minor",
    "version:major": "node scripts/bump-version.js major",
    "deploy:patch": "npm run version:patch && pm2 restart weixin-kimi-bot",
    "deploy:minor": "npm run version:minor && pm2 restart weixin-kimi-bot",
    "deploy:major": "npm run version:major && pm2 restart weixin-kimi-bot",
    "service:start": "pm2 start ecosystem.config.cjs",
    "service:stop": "pm2 stop weixin-kimi-bot",
    "service:restart": "pm2 restart weixin-kimi-bot",
    "service:status": "pm2 status weixin-kimi-bot",
    "service:logs": "pm2 logs weixin-kimi-bot",
    "service:delete": "pm2 delete weixin-kimi-bot",
    "service:monitor": "pm2 monitor"
  },
  "dependencies": {
    "qrcode-terminal": "^0.12.0",
    "nodemailer": "^6.9.13"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/nodemailer": "^6.4.15",
    "tsx": "^4",
    "typescript": "^5"
  },
  "keywords": [
    "weixin",
    "kimi",
    "ai",
    "bot",
    "ilink"
  ],
  "license": "MIT"
}
